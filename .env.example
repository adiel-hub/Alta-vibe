# =============================================================================
# Alta environment
# =============================================================================
# Local dev: copy this file to `.env.local` and fill in.
# Production: set these as env vars on Vercel (web) and Railway (worker).
# See DEPLOYMENT.md for the full walkthrough.
# =============================================================================

# --- Required: AI providers --------------------------------------------------
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# --- Required: web scraper for "scrape website into knowledge base" ---------
FIRECRAWL_API_KEY=

# --- Required: MongoDB (Railway) --------------------------------------------
# Railway → MongoDB plugin → copy MONGO_URL. Public networking must be ON
# for Vercel to reach it.
MONGODB_URI=
MONGODB_DB=alta_vibe

# --- Required in production: shared-secret API gate -------------------------
# Generate with: openssl rand -hex 32
# Both vars must hold the SAME value. NEXT_PUBLIC_ leaks to the browser by
# design (it's prototype hardening, not real auth — keeps a discovered
# preview URL from burning ElevenLabs / Anthropic quota).
# In production, missing APP_SHARED_SECRET returns 503 on every API route.
APP_SHARED_SECRET=
NEXT_PUBLIC_APP_SHARED_SECRET=

# --- Optional: Google OAuth (Calendar integration) --------------------------
# Required to let agents connect a user's Google Calendar (check_availability,
# book_meeting tools). Set up in https://console.cloud.google.com/apis/credentials:
#   1. Create a Web Application OAuth client.
#   2. Add authorized redirect URI:
#        <APP_BASE_URL>/api/integrations/google_calendar/oauth/callback
#      (e.g. https://your-app.vercel.app/api/integrations/google_calendar/oauth/callback)
#   3. Enable the "Google Calendar API" on the project.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Optional: Salesforce OAuth (CRM integration) ---------------------------
# Required to let agents connect a Salesforce org (contacts, leads, accounts,
# opportunities, cases, tasks). Create a Connected App in Salesforce Setup
# (App Manager → New Connected App) with OAuth enabled, then add the callback:
#   <APP_BASE_URL>/api/integrations/salesforce/oauth/callback
SALESFORCE_OAUTH_CLIENT_ID=
SALESFORCE_OAUTH_CLIENT_SECRET=

# --- Optional: Microsoft OAuth (Dynamics 365 + Outlook Calendar) ------------
# Shared by both the Dynamics 365 and Outlook Calendar integrations. Register
# an app in https://portal.azure.com → App registrations, add a Web platform
# redirect URI for each provider you enable:
#   <APP_BASE_URL>/api/integrations/dynamics365/oauth/callback
#   <APP_BASE_URL>/api/integrations/outlook_calendar/oauth/callback
# TENANT is the Azure AD tenant id (or "common" for multi-tenant; defaults to
# "common" when unset).
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT=

# --- Worker tuning (Railway worker service only) ----------------------------
# Concurrent turn jobs per worker process. Default 4.
WORKER_MAX_CONCURRENT=4
# Poll interval for new queued jobs (ms). Default 1000.
WORKER_POLL_INTERVAL_MS=1000
# How often the worker reaps stuck jobs across all agents (ms). Default 30000.
WORKER_REAP_INTERVAL_MS=30000

# --- Logging (server side: Vercel functions, worker) ------------------------
# Level: trace | debug | info | warn | error | off  (default: info)
LOG_LEVEL=info
# Category filter. Examples:
#   "*"                       — all categories enabled (default)
#   "api,turn-job"            — only those two
#   "*,!sse,!voice-provider"  — everything except SSE and provider chatter
# Available: api, auth, mongo, voice-provider, firecrawl, agent-sdk,
#            turn-job, capability (also capability:voice etc), widget,
#            integration, sse, worker
LOG_CATEGORIES=*
# Format: pretty (colored, dev) | json (structured, prod). Default: pretty
# in dev, json in production.
LOG_FORMAT=
# Trim noisy parts of each log line. Set to "false" to drop.
LOG_INCLUDE_TIMESTAMPS=true
LOG_INCLUDE_LEVEL=true
LOG_INCLUDE_CATEGORY=true

# --- Logging (browser side) -------------------------------------------------
# Mirrors LOG_LEVEL / LOG_CATEGORIES but for the React app. Set via Vercel
# env vars — these are bundled into the client.
# Categories: sse-client, store, chat, widget, workflow, test-call, ui
NEXT_PUBLIC_LOG_LEVEL=info
NEXT_PUBLIC_LOG_CATEGORIES=*
