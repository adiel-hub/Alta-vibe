# Anthropic API key for the builder agent (Claude Agent SDK + one-shot seeding)
ANTHROPIC_API_KEY=

# Voice provider API key (ElevenLabs Conversational AI under the hood — never exposed to the user)
ELEVENLABS_API_KEY=

# Firecrawl API key (used by the agent to scrape websites into the knowledge base)
FIRECRAWL_API_KEY=

# MongoDB (Railway-hosted) connection string and database name
MONGODB_URI=
MONGODB_DB=alta_vibe

# Shared secret to gate every /api/* route. Same value on both vars below.
# Not real auth — anti-discovery hardening for the no-auth prototype.
APP_SHARED_SECRET=
NEXT_PUBLIC_APP_SHARED_SECRET=

# Vercel Sandbox credentials (required when running the Agent SDK from a
# Vercel Function in production). See https://vercel.com/docs/vercel-sandbox.
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
VERCEL_TOKEN=
